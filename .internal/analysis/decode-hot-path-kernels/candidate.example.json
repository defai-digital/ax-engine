{
  "schema_version": "ax.decode_hot_path_kernel_candidate.v1",
  "candidate_id": "YYYY-MM-DD-short-name",
  "title": "Human-readable candidate title",
  "class": "graph_compile",
  "status": "prototype",
  "production_default": false,
  "feature_flag": "AX_MLX_EXAMPLE_FASTPATH",
  "profile": {
    "path": "profile.md",
    "source": "AX_MLX_DECODE_PROFILE",
    "model": "mlx-community/example-4bit",
    "prompt_tokens": 2048,
    "generation_tokens": 128,
    "build_commit": "same-commit-sha",
    "host": "macos-arm64",
    "dominant_stage": "post-attention",
    "stage_wall_share_pct": 25.0
  },
  "mechanism": {
    "path": "mechanism.md",
    "removed_costs": ["dispatches/token"],
    "why_mlx_cannot_remove": "Explain the current MLX graph boundary."
  },
  "correctness": {
    "path": "correctness.md",
    "oracle": "current_mlx",
    "greedy_parity": "passed",
    "numeric_tolerance": 0.001
  },
  "microbench": {
    "path": "microbench.json",
    "warmup_runs": 2,
    "measure_runs": 5,
    "host": "macos-arm64",
    "median_speedup_pct": 0.0
  },
  "real_graph_ab": {
    "path": "e2e-summary.md",
    "baseline_row": "baseline artifact row",
    "candidate_row": "candidate artifact row",
    "decode_speedup_pct": 0.0,
    "prefill_tok_s": 0.0,
    "ttft_ms": 0.0,
    "greedy_parity_passed": true
  },
  "rollback": {
    "default_off": true,
    "fallback": "current MLX path",
    "kill_switch": "AX_DISABLE_MLX_EXAMPLE_FASTPATH",
    "telemetry_counters": [
      "ax_mlx_example_attempts",
      "ax_mlx_example_hits",
      "ax_mlx_example_fallbacks"
    ]
  },
  "promotion": {
    "path": "promotion-decision.md",
    "decision": "prototype",
    "reason": "Evidence is not yet sufficient for promotion."
  }
}
