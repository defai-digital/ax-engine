{
  "name": "@ax-engine/sdk",
  "version": "6.8.2",
  "description": "JavaScript / TypeScript SDK for AX Engine v6 — local HTTP inference server",
  "type": "module",
  "main": "./index.js",
  "exports": {
    ".": {
      "import": "./index.js",
      "types": "./index.d.ts"
    },
    "./langchain": {
      "import": "./langchain.js",
      "types": "./langchain.d.ts"
    }
  },
  "types": "./index.d.ts",
  "files": [
    "index.js",
    "index.d.ts",
    "langchain.js",
    "langchain.d.ts",
    "README.md"
  ],
  "scripts": {
    "test": "node --test test/*.test.js",
    "test:types": "tsc -p tsconfig.types.json",
    "test:all": "npm run test && npm run test:types"
  },
  "engines": {
    "node": ">=24"
  },
  "peerDependencies": {
    "@langchain/core": ">=0.2"
  },
  "peerDependenciesMeta": {
    "@langchain/core": {
      "optional": true
    }
  },
  "devDependencies": {
    "typescript": "^7.0.2"
  },
  "keywords": ["llm", "inference", "mlx", "apple-silicon", "langchain"],
  "license": "Apache-2.0"
}
