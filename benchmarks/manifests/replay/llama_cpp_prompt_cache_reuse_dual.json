{
  "schema_version": "ax.engine_bench.manifest.v1",
  "id": "llama_cpp_prompt_cache_reuse_dual",
  "class": "replay",
  "scenario": "replay",
  "model": {
    "family": "qwen3_dense",
    "revision": "phase1-llama-cpp",
    "quant": "q4_k_m",
    "tokenizer_revision": "qwen-tokenizer-v1",
    "chat_template_revision": "chatml-v1"
  },
  "runtime": {
    "selected_backend": "llama_cpp",
    "support_tier": "llama_cpp",
    "resolution_policy": "allow_llama_cpp",
    "fallback_reason": "benchmark requested delegated runtime",
    "backend_adapter": {
      "kind": "llama_cpp_server_completion",
      "server_url": "http://127.0.0.1:8081"
    },
    "llama_cpp_preset": {
      "name": "safe_stepwise_server",
      "parallel_slots": 2,
      "continuous_batching": true,
      "logical_batch_size": 2048,
      "physical_batch_size": 512,
      "cache_prompt": true,
      "slot_save_path": null,
      "slot_restore_path": null,
      "speculative_decode_mode": "disabled",
      "metrics_endpoint": "server:/metrics"
    },
    "deterministic": true,
    "max_batch_tokens": 2048,
    "flags": {
      "prefix_cache": false
    }
  },
  "sampling": {
    "temperature": 0,
    "top_p": 1,
    "top_k": 0,
    "seed": 1234
  },
  "events": [
    {
      "t_ms": 0,
      "type": "submit",
      "request_id": "req-1",
      "prompt_ref": "prompts/prefix_a.txt",
      "output_tokens_target": 8,
      "prefix_group": "group-a"
    },
    {
      "t_ms": 40,
      "type": "submit",
      "request_id": "req-2",
      "prompt_ref": "prompts/prefix_a_variant.txt",
      "output_tokens_target": 8,
      "prefix_group": "group-a"
    }
  ],
  "checks": {
    "expect_deterministic": true,
    "require_prefix_reuse": true
  },
  "notes": "LlamaCpp replay example for delegated llama.cpp /completion prompt-cache reuse. Update runtime.backend_adapter.server_url before running directly. Treat any reported reuse as delegated backend evidence, not AX Engine scheduler or retained-block reuse."
}
